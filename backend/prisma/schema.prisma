// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  celebration
  thankyou
  inspiration
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique // login identity; DB enforces uniqueness
  passwordHash String // bcrypt hash — never the plaintext password
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  boards       Board[]
  cards        Card[]
  replies      Reply[]
}

model Board {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  Category
  imageUrl  String?
  author    String?
  createdAt DateTime @default(now())
  cards     Card[]

  @@index([userId])
}

model Card {
  id        String    @id @default(uuid())
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  // Card creator. Cascade so deleting a user wipes their cards along with
  // their boards.
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  gifUrl    String
  author    String?
  upvotes   Int       @default(0)
  pinned    Boolean   @default(false)
  pinnedAt  DateTime?
  createdAt DateTime  @default(now())
  replies   Reply[]

  @@index([boardId])
  @@index([userId])
}

model Reply {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  // Reply author. Cascade so deleting a user wipes their replies too.
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  gifUrl    String? // optional — a reply can be text-only or carry its own GIF
  author    String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([userId])
}
