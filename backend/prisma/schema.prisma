// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  celebration
  thankyou
  inspiration
}

model User {
  id           String      @id @default(uuid())
  username     String      @unique // login identity; DB enforces uniqueness
  passwordHash String // bcrypt hash — never the plaintext password
  isAdmin      Boolean     @default(false)
  createdAt    DateTime    @default(now())
  boards       Board[]
  cards        Card[]
  replies      Reply[]
  cardLikes    CardLike[]
  replyLikes   ReplyLike[]
}

model Board {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  category  Category
  imageUrl  String?
  author    String?
  createdAt DateTime @default(now())
  cards     Card[]

  @@index([userId])
}

model Card {
  id        String    @id @default(uuid())
  boardId   String
  board     Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  // Card creator. Nullable to allow anonymous/guest cards (spec §UA5). Signed-in
  // creators delete by userId match; guest creators delete by presenting the
  // per-card `guestKey` returned in the POST response — see deleteCard.
  // SetNull so deleting a user leaves the card intact instead of cascading it away.
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Random secret handed back to the browser when a guest creates a card. The
  // owning browser stores it in localStorage and returns it in `X-Guest-Key`
  // to authorize a delete. Null for signed-in cards and for legacy guest cards
  // created before this column existed (those stay undeletable).
  guestKey  String?
  message   String
  gifUrl    String
  author    String?
  upvotes   Int        @default(0)
  pinned    Boolean    @default(false)
  pinnedAt  DateTime?
  createdAt DateTime   @default(now())
  replies   Reply[]
  likes     CardLike[]

  @@index([boardId])
  @@index([userId])
}

model Reply {
  id        String      @id @default(uuid())
  cardId    String
  card      Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  // Reply author. Cascade so deleting a user wipes their replies too.
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  gifUrl    String? // optional — a reply can be text-only or carry its own GIF
  author    String?
  likes     Int         @default(0) // denormalized count of ReplyLike rows
  likedBy   ReplyLike[]
  createdAt DateTime    @default(now())

  @@index([cardId])
  @@index([userId])
}

// Join rows recording which user liked which card / reply. The composite
// primary key enforces "one like per user per target" at the DB level; the
// `upvotes` / `likes` integer columns above stay as denormalized counts kept
// in sync inside the toggle transactions (see the controllers).
model CardLike {
  userId    String
  cardId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
  @@index([cardId])
}

model ReplyLike {
  userId    String
  replyId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@id([userId, replyId])
  @@index([replyId])
}
