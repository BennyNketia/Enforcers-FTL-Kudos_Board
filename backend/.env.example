# Backend environment variables — copy this file to `.env` and fill in values.
# `.env` is gitignored, so your real key is never committed.
#
#   cp .env.example .env
#   # then paste your key after OPENROUTER_API_KEY=

# Port the Express server listens on. The frontend dev proxy targets 3000.
PORT=3000

# --- Database (Prisma / PostgreSQL) ---------------------------------------
# Prisma connection string. Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local Postgres.app: user = your macOS username, usually no password, port 5432.
#   e.g. postgresql://yourname@localhost:5432/kudos-board
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kudos-board

# --- OpenRouter (AI features) ---------------------------------------------
# Get a key at https://openrouter.ai/keys  (free tier works for the :free models).
OPENROUTER_API_KEY=

# Preferred model for the AI composer. Any OpenRouter model id works. This is
# only the FIRST choice — if it's rate-limited (free models often are), the
# backend automatically falls back through a chain of other free models
# (see src/lib/openrouter.js → FALLBACK_MODELS), so the feature keeps working.
# Leave as-is unless you have a paid model you'd rather prioritize.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: sent to OpenRouter for usage ranking (purely cosmetic).
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Kudos Board

# --- GIPHY (GIF search proxy) ---------------------------------------------
# Get a key at https://developers.giphy.com/dashboard/ (free). Keeps the key
# server-side; the frontend calls GET /api/giphy/search instead of GIPHY direct.
GIPHY_API_KEY=

# Optional: comma-separated list of allowed CORS origins. Defaults to allowing
# the Vite dev server. Leave blank to allow all origins in development.
CORS_ORIGIN=

