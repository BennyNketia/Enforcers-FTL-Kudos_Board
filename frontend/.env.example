# Frontend environment variables (copy to .env to override)

# When "true", the app talks to the real Express API instead of localStorage.
VITE_USE_API=false

# Base URL for the API (used when VITE_USE_API=true). Dev proxy handles /api.
VITE_API_BASE_URL=/api

# Optional: your own GIPHY API key. Falls back to a public beta key / demo GIFs.
VITE_GIPHY_KEY=
