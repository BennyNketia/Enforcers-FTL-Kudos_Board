    {
      "name": "Boards",
      "item": [
        {
          "name": "GET /api/boards (list)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards?filter=all&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards"],
              "query": [
                { "key": "filter", "value": "all", "description": "one of: all, recent, mine, celebration, thankyou, inspiration" },
                { "key": "search", "value": "", "description": "case-insensitive title contains" }
              ]
            }
          }
        },
        {
          "name": "GET /api/boards/:boardId",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/{{boardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "{{boardId}}"]
            }
          }
        },
        {
          "name": "POST /api/boards (create)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.id) pm.collectionVariables.set('boardId', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My test board\",\n  \"category\": \"celebration\",\n  \"imageUrl\": \"\",\n  \"author\": \"Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/boards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards"]
            },
            "description": "category must be one of: celebration, thankyou, inspiration."
          }
        },
        {
          "name": "DELETE /api/boards/:boardId",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/{{boardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "{{boardId}}"]
            }
          }
        }
      ]
    },
